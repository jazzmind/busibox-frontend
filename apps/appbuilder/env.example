# =============================================================================
# BUSIBOX APP TEMPLATE - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env.local for local development:
#   cp env.example .env.local
#
# For Busibox deployments, environment variables are automatically
# generated from Ansible vault - DO NOT use this file for those deployments.

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Node environment
NODE_ENV=development

# App name (used for token audience validation and cookies)
APP_NAME=busibox-appbuilder
# Explicit SSO token audience(s), comma-separated (set to your manifest id/path audience)
SSO_AUDIENCE=

# Port for local dev server
PORT=3004

# Base path for routing (if behind nginx proxy)
# For nginx proxy at /builder: set to /builder
# For direct access: leave empty
NEXT_PUBLIC_BASE_PATH=

# App URL (for redirects and links)
NEXT_PUBLIC_APP_URL=http://localhost:3004

# =============================================================================
# AUTHENTICATION (Required)
# =============================================================================

# Busibox Portal URL (where users authenticate)
# Local:         http://localhost:3000
# Proxmox Prod:  http://10.96.200.201:3000
# Proxmox Stage: http://10.96.201.201:3000
NEXT_PUBLIC_BUSIBOX_PORTAL_URL=http://localhost:3000

# AuthZ Service (for token exchange)
# Local Docker:  http://localhost:8010
# Proxmox Prod:  http://10.96.200.210:8010
# Proxmox Stage: http://10.96.201.210:8010
AUTHZ_BASE_URL=http://localhost:8010

# =============================================================================
# BACKEND SERVICES
# =============================================================================

# Backend API URL (where to proxy requests for custom backend services)
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:8000

# Default API audience for token exchange
# Use data-api when your app stores data via data-api (see lib/data-api-client.ts)
DEFAULT_API_AUDIENCE=data-api

# Data API URL (for structured data storage)
# Local Docker:  http://localhost:8002
# Proxmox Prod:  http://10.96.200.206:8002
# Proxmox Stage: http://10.96.201.206:8002
DATA_API_URL=http://localhost:8002

# Agent API URL (for AI agent interactions)
# Local Docker:  http://localhost:8000
# Proxmox Prod:  http://10.96.200.207:8000
# Proxmox Stage: http://10.96.201.207:8000
AGENT_API_URL=http://localhost:8000

# =============================================================================
# OPTIONAL: LOCAL DEVELOPMENT
# =============================================================================

# Test session JWT (for local development without Busibox Portal)
# Get this from AuthZ service after authentication
# TEST_SESSION_JWT=eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9...

# Enable verbose authz logging
VERBOSE_AUTHZ_LOGGING=false

# Skip TLS verification for self-signed certs
# WARNING: NEVER use this in production!
# NODE_TLS_REJECT_UNAUTHORIZED=0

# =============================================================================
# OPTIONAL: DEBUGGING
# =============================================================================

# Enable debug logging
DEBUG=false

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
#
# 1. Copy this file:
#    cp env.example .env.local
#
# 2. Configure AUTHZ_BASE_URL and DATA_API_URL for your environment
#
# 3. Set TEST_SESSION_JWT for local development without Busibox Portal
#
# 4. Start development server:
#    npm run dev
#
#
# BUSIBOX DEPLOYMENT
# ------------------
# For Busibox deployments, DO NOT use this file.
# Environment variables are generated from Ansible vault.
# See: busibox/provision/ansible/group_vars/all/apps.yml

# Cross-App API Paths
# These configure where this app finds other apps' APIs.
# In production, apps are behind nginx at /<app-name>.
# In local dev, override with full URLs (e.g. http://localhost:3006).
NEXT_PUBLIC_PORTAL_BASE_PATH="/portal"
NEXT_PUBLIC_DOCUMENTS_BASE_PATH="/documents"
NEXT_PUBLIC_AGENTS_BASE_PATH="/agents"
NEXT_PUBLIC_MEDIA_BASE_PATH="/media"
NEXT_PUBLIC_CHAT_BASE_PATH="/chat"
