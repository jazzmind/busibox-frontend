# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ai_portal"

# Application URL (runtime server-side)
# Used for email links and OAuth callbacks
# Note: NEXT_PUBLIC_APP_URL is baked at build time for client-side code
APP_URL="https://your-domain.com/portal"

# WebAuthn / Passkey RP ID (domain only, no protocol or path)
# Must match the domain the browser sees. Set this explicitly when APP_URL
# uses an internal hostname (e.g. http://portal:3000 inside Docker).
# If unset, derived from APP_URL hostname.
WEBAUTHN_RP_ID="your-domain.com"

# Email (Resend)
RESEND_API_KEY="re_xxxxxxxxxxxxx"
EMAIL_FROM="Busibox Portal <noreply@your-domain.com>"

# Admin Configuration
ADMIN_EMAIL="admin@your-domain.com"
ALLOWED_EMAIL_DOMAINS="your-domain.com,another-domain.com"

# SSO Configuration
SSO_JWT_SECRET="your-sso-jwt-secret"
SSO_TOKEN_EXPIRY="900"  # 15 minutes in seconds

# LLM Configuration
LITELLM_BASE_URL="http://localhost:4000/v1"
LITELLM_API_KEY="your-litellm-api-key"
OPENAI_API_KEY="sk-xxxxxxxxxxxxx"  # For video generation

# GitHub OAuth (for deployment management)
GITHUB_CLIENT_ID="your_github_oauth_app_client_id"
GITHUB_CLIENT_SECRET="your_github_oauth_app_client_secret"
GITHUB_REDIRECT_URI="https://your-domain.com/api/admin/github/callback"

# Container SSH Access (for remote deployments)
# Only needed if deploying to different containers
CONTAINER_SSH_PRIVATE_KEY="base64:your-base64-encoded-private-key"
# Or path to key file:
# CONTAINER_SSH_PRIVATE_KEY="/path/to/private/key"

# Container IPs (for deployments)
# CURRENT_CONTAINER_IP is used to determine if deployment is local
CURRENT_CONTAINER_IP="10.96.200.201"  # IP of container running busibox-portal
APPS_CONTAINER_IP="10.96.200.201"
AGENT_CONTAINER_IP="10.96.200.202"
POSTGRES_CONTAINER_IP="10.96.200.203"

# AuthZ Service Configuration
AUTHZ_BASE_URL="http://10.96.200.210:8010"

# Documentation API
# Server-side URL for fetching docs (internal Docker network or localhost)
DOCS_API_URL="http://docs-api:8004"
# Client-side URL (optional, uses /api/docs via nginx by default)
# NEXT_PUBLIC_DOCS_API_URL="/api/docs"

# Data API (Files Service)
# Used for library management and document operations
DATA_API_HOST="10.96.200.206"
DATA_API_PORT="8002"

# Deployment Service
# NOTE: This is automatically configured during deployment via Ansible/Docker.
# Do NOT set this in your .env file - it's set dynamically based on environment:
#   - Docker dev: http://deploy-api:8011/api/v1/deployment
#   - Docker prod: http://deploy-api:8011/api/v1/deployment
#   - Ansible staging: http://10.96.200.210:8011/api/v1/deployment
#   - Ansible production: http://10.96.200.210:8011/api/v1/deployment
# DEPLOYMENT_SERVICE_URL - DO NOT SET (configured automatically)

# Application
NODE_ENV="production"
PORT="3000"

# Cross-App API Paths
# These configure where this app finds other apps' APIs.
# In production, apps are behind nginx at /<app-name>.
# In local dev, override with full URLs (e.g. http://localhost:3006).
NEXT_PUBLIC_PORTAL_BASE_PATH="/portal"
NEXT_PUBLIC_DOCUMENTS_BASE_PATH="/documents"
NEXT_PUBLIC_AGENTS_BASE_PATH="/agents"
NEXT_PUBLIC_MEDIA_BASE_PATH="/media"
NEXT_PUBLIC_CHAT_BASE_PATH="/chat"
