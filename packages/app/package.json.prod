{
  "name": "@jazzmind/busibox-app",
  "version": "3.0.34",
  "description": "Reusable components for Busibox applications",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "default": "./dist/components/index.js"
    },
    "./contexts": {
      "types": "./dist/contexts/index.d.ts",
      "default": "./dist/contexts/index.js"
    },
    "./layout": {
      "types": "./dist/layout/index.d.ts",
      "default": "./dist/layout/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    },
    "./lib": {
      "types": "./dist/lib/index.d.ts",
      "default": "./dist/lib/index.js"
    },
    "./lib/utils": {
      "types": "./dist/lib/utils.d.ts",
      "default": "./dist/lib/utils.js"
    },
    "./lib/icons": {
      "types": "./dist/lib/icons.d.ts",
      "default": "./dist/lib/icons.js"
    },
    "./lib/authz": {
      "types": "./dist/lib/authz/index.d.ts",
      "default": "./dist/lib/authz/index.js"
    },
    "./lib/authz/*": {
      "types": "./dist/lib/authz/*.d.ts",
      "default": "./dist/lib/authz/*.js"
    },
    "./lib/agent": {
      "types": "./dist/lib/agent/index.d.ts",
      "default": "./dist/lib/agent/index.js"
    },
    "./lib/agent/*": {
      "types": "./dist/lib/agent/*.d.ts",
      "default": "./dist/lib/agent/*.js"
    },
    "./lib/data": {
      "types": "./dist/lib/data/index.d.ts",
      "default": "./dist/lib/data/index.js"
    },
    "./lib/data/*": {
      "types": "./dist/lib/data/*.d.ts",
      "default": "./dist/lib/data/*.js"
    },
    "./lib/search": {
      "types": "./dist/lib/search/index.d.ts",
      "default": "./dist/lib/search/index.js"
    },
    "./lib/search/*": {
      "types": "./dist/lib/search/*.d.ts",
      "default": "./dist/lib/search/*.js"
    },
    "./lib/deploy/*": {
      "types": "./dist/lib/deploy/*.d.ts",
      "default": "./dist/lib/deploy/*.js"
    },
    "./lib/bridge/*": {
      "types": "./dist/lib/bridge/*.d.ts",
      "default": "./dist/lib/bridge/*.js"
    },
    "./lib/docs/*": {
      "types": "./dist/lib/docs/*.d.ts",
      "default": "./dist/lib/docs/*.js"
    },
    "./lib/media/*": {
      "types": "./dist/lib/media/*.d.ts",
      "default": "./dist/lib/media/*.js"
    },
    "./lib/next/*": {
      "types": "./dist/lib/next/*.d.ts",
      "default": "./dist/lib/next/*.js"
    },
    "./lib/http/*": {
      "types": "./dist/lib/http/*.d.ts",
      "default": "./dist/lib/http/*.js"
    },
    "./lib/date-utils": {
      "types": "./dist/lib/date-utils.d.ts",
      "default": "./dist/lib/date-utils.js"
    },
    "./lib/sse": {
      "types": "./dist/lib/sse.d.ts",
      "default": "./dist/lib/sse.js"
    },
    "./types/next-auth": {
      "types": "./dist/types/next-auth.d.ts",
      "default": "./dist/types/next-auth.js"
    },
    "./components/auth/*": {
      "types": "./dist/components/auth/*.d.ts",
      "default": "./dist/components/auth/*.js"
    },
    "./components/documents/*": {
      "types": "./dist/components/documents/*.d.ts",
      "default": "./dist/components/documents/*.js"
    },
    "./components/account/*": {
      "types": "./dist/components/account/*.d.ts",
      "default": "./dist/components/account/*.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "peerDependencies": {
    "next": "^16.0.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^9.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@simplewebauthn/browser": "^13.0.0",
    "@simplewebauthn/server": "^13.0.0",
    "@simplewebauthn/types": "12.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jose": "^6.1.0",
    "katex": "^0.16.25",
    "lucide-react": "^0.546.0",
    "openai": "^6.2.0",
    "react-dropzone": "^14.3.5",
    "react-force-graph-2d": "^1.29.1",
    "react-hot-toast": "^2.6.0",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sharp": "^0.34.5",
    "ssh2": "^1.17.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ssh2": "^1.15.1",
    "dotenv": "^16.4.5",
    "jest": "^29.7.0",
    "next": "^16.0.10",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwindcss": "^4",
    "ts-jest": "^29.1.2",
    "typescript": "^5"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jazzmind/busibox-frontend.git"
  },
  "keywords": [
    "react",
    "nextjs",
    "ui",
    "components",
    "busibox"
  ],
  "author": "Sonnenreich",
  "license": "MIT"
}
